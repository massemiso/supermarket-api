# ==============================================================================
# Copy this file to '.env' and fill in the actual values.
# DO NOT commit the '.env' file to version control.
# ==============================================================================

# --- DATABASE CONFIGURATION ---
POSTGRES_DB=your_db_name
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password

# --- SECURITY & JWT ---
JWT_SECRET=your_super_secret_high_entropy_key_here_at_least_64_characters_long
JWT_USER_GENERATOR=YOUR_USER_GENERATOR_HERE
# 1 hour
JWT_EXPIRATION=3600000

# --- INITIAL ADMIN IN PRODUCTION SETUP (Used by UserSeeder) ---
# These are the credentials used by the CommandLineRunner to bootstrap the app
PROD_ADMIN_USERNAME=admin
PROD_ADMIN_PASSWORD=admin_secure_password
PROD_ADMIN_EMAIL=admin@supermarket.com

# --- SERVER ---
SERVER_PORT=8080

# Uncomment below to enable production mode
#SPRING_PROFILES_ACTIVE=prod